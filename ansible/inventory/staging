# ansible/inventory/staging
# Replace IP addresses with your actual server IPs

[webservers]
staging-web-01 ansible_host=192.168.1.10 ansible_user=deploy ansible_ssh_private_key_file=~/.ssh/campusops_deploy

[appservers]
staging-api-01 ansible_host=192.168.1.11 ansible_user=deploy ansible_ssh_private_key_file=~/.ssh/campusops_deploy

[dbservers]
staging-db-01  ansible_host=192.168.1.12 ansible_user=deploy ansible_ssh_private_key_file=~/.ssh/campusops_deploy

[campus_staging:children]
webservers
appservers
dbservers

[campus_staging:vars]
ansible_python_interpreter=/usr/bin/python3
env=staging
app_dir=/opt/campusops
